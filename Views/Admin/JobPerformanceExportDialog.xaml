<Window x:Class="CAKA.PerformanceApp.Views.Admin.JobPerformanceExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel dışa aktarma ayarları"
        Height="220" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Padding="20" Background="{StaticResource BackgroundBrush}">
        <StackPanel>
            <TextBlock Text="Bu rapor yalnızca seçilen işe ait kayıtları içerir." Style="{StaticResource SubtitleTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12"/>
            <TextBlock Text="Çalışan başına maksimum hedef süre (saat)" Style="{StaticResource SubtitleTextStyle}" Margin="0,0,0,4"/>
            <TextBox x:Name="TargetHoursBox" Padding="10,8"/>
            <TextBlock Text="Örn: 40 (virgül veya nokta ile ondalık girebilirsiniz)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,16" FontSize="12"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="İptal" Width="100" Margin="0,0,8,0" Padding="10,8"
                        Click="Cancel_Click" Background="{StaticResource BorderBrush}" Foreground="{StaticResource TextPrimaryBrush}"/>
                <Button Content="Devam" Width="120" Padding="10,8" Style="{StaticResource PrimaryButtonStyle}"
                        Click="Ok_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
